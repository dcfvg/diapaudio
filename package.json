{
  "name": "diapaudio-react",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:sample": "node scripts/dev-sample.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint --max-warnings=0 src",
    "lint:fix": "eslint src --fix --max-warnings=0",
    "format": "prettier --write \"src/**/*.{js,jsx,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,json,css}\"",
    "test": "NODE_OPTIONS='--no-warnings' vitest run",
    "test:watch": "NODE_OPTIONS='--no-warnings' vitest",
    "test:coverage": "NODE_OPTIONS='--no-warnings' vitest run --coverage",
    "check": "npm run lint && npm test && npm run build"
  },
  "dependencies": {
    "@remixicon/react": "^4.9.0",
    "@zip.js/zip.js": "^2.8.26",
    "date-fns": "^4.3.0",
    "fixts": "^1.4.0",
    "i18next": "^26.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-dropzone": "^15.0.0",
    "react-hotkeys-hook": "^5.3.2",
    "react-i18next": "^17.0.8",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.7",
    "baseline-browser-mapping": "^2.10.32",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "vite": "^8.0.14",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.7"
  }
}
